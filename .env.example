# ─────────────────────────────────────────────────────────────────────────────
# Portfolio Optimizer — Environment Variables Template
#
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio_optimizer

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for GPT-4o LLM explanation node.
# If left empty, a template-based fallback explanation is used.
OPENAI_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Quantum Engine ────────────────────────────────────────────────────────────
# Maximum wall-clock seconds for a single quantum optimization run (10–600)
QUANTUM_TIMEOUT_SECONDS=60
# Maximum number of assets for quantum optimization (2–20)
MAX_QUANTUM_ASSETS=8

# ── Data / Caching ────────────────────────────────────────────────────────────
# Redis TTL for cached price data in seconds (minimum 60)
CACHE_TTL_SECONDS=3600

# ── Portfolio Metrics ─────────────────────────────────────────────────────────
# Annual risk-free rate used in Sharpe ratio calculation (0.0–0.2)
RISK_FREE_RATE=0.02

GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_personal_access_token_here
