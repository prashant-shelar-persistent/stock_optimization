# ─────────────────────────────────────────────────────────────────────────────
# Portfolio Optimizer — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml
test-results/

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
*.tsbuildinfo

# ── IDE & editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Database migrations (keep alembic versions, ignore generated) ─────────────
# Keep: backend/alembic/versions/*.py
# Ignore: nothing — all migration files should be committed

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Terraform ─────────────────────────────────────────────────────────────────
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/.terraform.lock.hcl
infra/terraform.tfvars

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
.cache/
.sasva/
