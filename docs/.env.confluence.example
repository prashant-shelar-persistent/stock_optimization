# ─────────────────────────────────────────────────────────────────────────────
# Confluence Upload Configuration
# Copy this file to .env.confluence and fill in your values.
# NEVER commit .env.confluence to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Confluence base URL (no trailing slash)
# Cloud example:  https://your-org.atlassian.net/wiki
# Server example: https://confluence.your-company.com
CONFLUENCE_URL=https://your-org.atlassian.net/wiki

# Confluence Space Key (e.g. "PORTOPT", "DOCS", "ENG")
CONFLUENCE_SPACE_KEY=PORTOPT

# Title of the root parent page under which all docs will be created.
# The page must already exist in the space.
CONFLUENCE_PARENT_PAGE_TITLE=Portfolio Optimizer Documentation

# Authentication — choose ONE of the two methods below:

# Method 1 (Recommended for Confluence Cloud): API Token
#   Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-api-token-here

# Method 2 (Confluence Server / Data Center): Personal Access Token (PAT)
# Leave CONFLUENCE_EMAIL empty and set only CONFLUENCE_PAT.
# CONFLUENCE_PAT=your-personal-access-token-here

# ─── Optional tuning ──────────────────────────────────────────────────────────

# Dry-run mode: set to "true" to preview what would be uploaded without
# actually creating/updating any pages.
CONFLUENCE_DRY_RUN=false

# Number of concurrent upload workers (default: 4)
CONFLUENCE_WORKERS=4

# If "true", existing pages with the same title will be updated in-place.
# If "false", existing pages are skipped.
CONFLUENCE_UPDATE_EXISTING=true

# Label applied to every uploaded page (optional, leave blank to skip)
CONFLUENCE_PAGE_LABEL=portfolio-optimizer
