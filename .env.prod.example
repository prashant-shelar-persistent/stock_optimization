# ─────────────────────────────────────────────────────────────────────────────
# Portfolio Optimizer — Production Environment Variables Template
#
# Usage:
#   cp .env.prod.example .env.prod
#   # Edit .env.prod and fill in all required values
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# SECURITY NOTICE:
#   - NEVER commit .env.prod to version control.
#   - Add .env.prod to .gitignore.
#   - In AWS deployments, prefer AWS Secrets Manager over this file.
#   - Rotate all secrets (passwords, API keys) regularly.
#   - Use strong, randomly generated passwords (e.g., `openssl rand -hex 32`).
#
# Required variables are marked with [REQUIRED].
# Optional variables have defaults shown after the `:-` in docker-compose.prod.yml.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL superuser credentials
POSTGRES_USER=portfolio_optimizer
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password_here
POSTGRES_DB=portfolio_optimizer

# [REQUIRED] Full async DSN used by SQLAlchemy + asyncpg
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://portfolio_optimizer:CHANGE_ME_strong_postgres_password_here@postgres:5432/portfolio_optimizer

# ── Redis ─────────────────────────────────────────────────────────────────────
# [REQUIRED] Redis AUTH password (must match requirepass in redis command)
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# [REQUIRED] Redis connection URLs (include password in the URL)
REDIS_URL=redis://:CHANGE_ME_strong_redis_password_here@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_strong_redis_password_here@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_strong_redis_password_here@redis:6379/2

# ── OpenAI ────────────────────────────────────────────────────────────────────
# [REQUIRED] OpenAI API key for GPT-4o LLM explanation node
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-CHANGE_ME_your_openai_api_key_here

# ── Application ───────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Quantum solver timeout in seconds (increase for larger circuits)
QUANTUM_TIMEOUT_SECONDS=60

# Maximum number of assets for quantum optimization (QUBO size grows exponentially)
MAX_QUANTUM_ASSETS=8

# Redis cache TTL for market data in seconds (1 hour default)
CACHE_TTL_SECONDS=3600

# Risk-free rate for Sharpe ratio calculation (annualised, e.g. 0.05 = 5%)
RISK_FREE_RATE=0.02

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://portfolio-optimizer.example.com

# ── Uvicorn ───────────────────────────────────────────────────────────────────
# Number of Uvicorn worker processes (recommended: 2 × CPU cores)
UVICORN_WORKERS=4

# ── Celery ────────────────────────────────────────────────────────────────────
# Number of Celery worker processes per container
CELERY_CONCURRENCY=4

# ── Docker Images ─────────────────────────────────────────────────────────────
# Pre-built image tags (used when pulling from a registry instead of building)
# Leave blank to build locally from Dockerfiles.
BACKEND_IMAGE=portfolio-optimizer-backend:latest
FRONTEND_IMAGE=portfolio-optimizer-frontend:latest

# ── Nginx / TLS ───────────────────────────────────────────────────────────────
# Host ports for nginx
HTTP_PORT=80
HTTPS_PORT=443

# Your production domain (used in nginx server_name and CORS)
DOMAIN=portfolio-optimizer.example.com

# Vite build-time API URLs (baked into the frontend bundle)
VITE_API_BASE_URL=https://portfolio-optimizer.example.com
VITE_WS_BASE_URL=wss://portfolio-optimizer.example.com

# ── Prometheus ────────────────────────────────────────────────────────────────
# Host port for Prometheus UI (restrict access via firewall in production)
PROMETHEUS_PORT=9090

# Prometheus data retention
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB

# External URL for Prometheus (used in alert annotations)
PROMETHEUS_EXTERNAL_URL=http://prometheus.portfolio-optimizer.example.com

# ── Alertmanager ─────────────────────────────────────────────────────────────
# External URL for Alertmanager (used in alert links)
ALERTMANAGER_EXTERNAL_URL=http://alertmanager.portfolio-optimizer.example.com

# Slack webhook URL for alert notifications (optional)
ALERTMANAGER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME

# Slack channel for alerts (e.g., #alerts-portfolio-optimizer)
ALERTMANAGER_SLACK_CHANNEL=#alerts-portfolio-optimizer

# PagerDuty integration key for critical alerts (optional)
ALERTMANAGER_PAGERDUTY_SERVICE_KEY=CHANGE_ME_pagerduty_integration_key

# SMTP settings for email alerts (optional)
ALERTMANAGER_SMTP_HOST=smtp.example.com:587
ALERTMANAGER_SMTP_FROM=alerts@portfolio-optimizer.example.com
ALERTMANAGER_SMTP_USERNAME=alerts@portfolio-optimizer.example.com
ALERTMANAGER_SMTP_PASSWORD=CHANGE_ME_smtp_password
ALERTMANAGER_EMAIL_TO=oncall@portfolio-optimizer.example.com

# ── Grafana ───────────────────────────────────────────────────────────────────
# Host port for Grafana UI (restrict access via firewall in production)
GRAFANA_PORT=3000

# [REQUIRED] Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password_here

# [REQUIRED] Grafana secret key for signing cookies and tokens
# Generate with: openssl rand -hex 32
GRAFANA_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Grafana domain and root URL (for correct redirect URLs)
GRAFANA_DOMAIN=grafana.portfolio-optimizer.example.com
GRAFANA_ROOT_URL=https://grafana.portfolio-optimizer.example.com
